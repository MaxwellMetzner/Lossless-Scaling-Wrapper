<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Lossless_Scaling_Wrapper</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <Target Name="GenerateEnvExample" BeforeTargets="BeforeBuild" Condition="!Exists('$(ProjectDir).env.example')">
    <ItemGroup>
      <EnvExampleLines Include="# .env.example - generated by build" />
      <EnvExampleLines Include="# Place environment overrides here. This file is created once on initial build." />
      <EnvExampleLines Include="# Example: set the Lossless Scaling executable path" />
      <EnvExampleLines Include="LOSSLESS_SCALING_PATH=&quot;C:\Program Files (x86)\Steam\steamapps\common\Lossless Scaling\LosslessScaling.exe&quot;" />
      <EnvExampleLines Include="# Or use a placeholder to remind users to set the real path" />
      <EnvExampleLines Include="# LOSSLESS_SCALING_PATH=&lt;LOSSLESS_SCALING_EXE&gt;" />
    </ItemGroup>

    <WriteLinesToFile
      File="$(ProjectDir).env.example"
      Lines="@(EnvExampleLines)"
      Overwrite="false"
      Encoding="UTF-8" />

    <Message Importance="high" Text="Generated .env.example in $(ProjectDir)" Condition="Exists('$(ProjectDir).env.example')" />
  </Target>

</Project>
